# Copy this to .env for local testing (never commit .env to git)

# Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Robinhood credentials
RH_USERNAME=your@email.com
RH_PASSWORD=yourpassword

# Optional: TOTP secret from your authenticator app
# If you use Google Authenticator / Authy, this is the secret key shown
# when you first set up 2FA (looks like: JBSWY3DPEHPK3PXP)
# If blank, the cached session from setup_login.py is used instead
RH_TOTP_SECRET=

# Path to state file (default: /data/state.json on Railway)
# STATE_FILE_PATH=/data/state.json
